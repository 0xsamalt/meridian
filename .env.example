# --- Storacha UCAN auth (replaces deprecated web3.storage API tokens) ---
# One-time setup:
#   npx ucan-key ed --json                          → STORACHA_AGENT_KEY
#   w3 login you@example.com
#   w3 space create meridian-keeper
#   w3 delegation create <did:key:z6Mk...> \
#     --can blob/add --can index/add \
#     --can filecoin/offer --can upload/add | base64  → STORACHA_DELEGATION
